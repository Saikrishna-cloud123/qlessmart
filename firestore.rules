rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid + '_admin'));
    }

    function hasRole(role) {
      return isSignedIn() &&
        (exists(/databases/$(database)/documents/user_roles/$(request.auth.uid + '_' + role)) || isAdmin());
    }

    // ── Profiles ──────────────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── OTPs ──────────────────────────────────────────────────────────────
    match /otps/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── User Roles ────────────────────────────────────────────────────────
    match /user_roles/{docId} {
      allow read: if isSignedIn();
      // Allow users to create their own 'customer' role during signup
      // Also allow Admin to manage all roles
      allow create: if (isOwner(docId.split('_')[0]) && docId.split('_')[1] == 'customer') || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Marts ─────────────────────────────────────────────────────────────
    match /marts/{martId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if (isSignedIn() && resource.data.owner_id == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Branches ──────────────────────────────────────────────────────────
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // ── Employees ─────────────────────────────────────────────────────────
    match /employees/{empId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // ── Sessions ──────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ── Cart Items ────────────────────────────────────────────────────────
    match /cart_items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // ── Invoices ──────────────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Carts (legacy / summary collection) ──────────────────────────────
    match /carts/{cartId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    // Default fallback rules
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

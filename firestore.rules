rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid + '_' + role));
    }

    // ── Profiles ──────────────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── User Roles ────────────────────────────────────────────────────────
    match /user_roles/{docId} {
      allow read: if isSignedIn();
      // Only admins can write roles (or create via server-side admin SDK)
      allow write: if false; // Managed by admin SDK / API
    }

    // ── Marts ─────────────────────────────────────────────────────────────
    match /marts/{martId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.owner_id == request.auth.uid;
      allow delete: if false;
    }

    // ── Branches ──────────────────────────────────────────────────────────
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // ── Employees ─────────────────────────────────────────────────────────
    match /employees/{empId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // ── Sessions ──────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── Cart Items ────────────────────────────────────────────────────────
    match /cart_items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // ── Invoices ──────────────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Audit Logs ────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Carts (legacy / summary collection) ──────────────────────────────
    match /carts/{cartId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }
  }
}
